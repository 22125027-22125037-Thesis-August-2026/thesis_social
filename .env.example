# Application
SOCIAL_APP_PORT=8080

# PostgreSQL
SOCIAL_DB_HOST=localhost
SOCIAL_DB_PORT=5432
SOCIAL_DB_NAME=social_features
SOCIAL_DB_USER=social
SOCIAL_DB_PASSWORD=social
SOCIAL_DB_URL=jdbc:postgresql://${SOCIAL_DB_HOST}:${SOCIAL_DB_PORT}/${SOCIAL_DB_NAME}

# RabbitMQ
SOCIAL_RABBIT_HOST=localhost
SOCIAL_RABBIT_PORT=5672
SOCIAL_RABBIT_USER=guest
SOCIAL_RABBIT_PASSWORD=guest
SOCIAL_RABBIT_MGMT_PORT=15672
SOCIAL_RABBIT_WEB_STOMP_PORT=15674

# STOMP Relay
SOCIAL_STOMP_RELAY_HOST=localhost
SOCIAL_STOMP_RELAY_PORT=61613
SOCIAL_STOMP_RELAY_LOGIN=guest
SOCIAL_STOMP_RELAY_PASSCODE=guest
SOCIAL_STOMP_SYSTEM_LOGIN=guest
SOCIAL_STOMP_SYSTEM_PASSCODE=guest

# Security
SOCIAL_JWT_PUBLIC_KEY=
SOCIAL_JWT_SIGNING_KID=
SOCIAL_JWT_ISSUER=therapist-auth
SOCIAL_JWT_AUDIENCE=social-features

# CORS
SOCIAL_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Events
SOCIAL_EVENTS_EXCHANGE=social.domain.events
SOCIAL_EVENTS_ROUTING_PREFIX=social
